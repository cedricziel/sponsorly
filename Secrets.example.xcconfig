// Secrets.example.xcconfig
//
// Template for Login with Amazon (LWA) credentials.
//
// Setup:
//   1. Copy this file to `Secrets.xcconfig` (which is git-ignored).
//   2. Fill in the values from your Amazon Ads / Login with Amazon Security Profile
//      at https://developer.amazon.com/settings/console/securityprofile/overview.html
//   3. Register the redirect URI `amzn-com.cedricziel.sponsorly://oauth` as an
//      "Allowed Return URL" on that Security Profile.
//   4. Run `xcodegen generate`.
//
// NEVER commit the real `Secrets.xcconfig`.

LWA_CLIENT_ID = amzn1.application-oa2-client.REPLACE_ME
LWA_CLIENT_SECRET = amzn1.oa2-cs.v1.REPLACE_ME
